# To use this file move it to /etc/logrotate.d/inspircd

@ABSOLUTE_LOG_DIR@/*.log {
	compress
	%ifndef DISABLE_OWNERSHIP create 0644 @USER_NAME@ @GROUP_NAME@
	dateext
	delaycompress
	missingok
	notifempty
	rotate 8
	weekly
	postrotate
		if [ -r "@ABSOLUTE_RUNTIME_DIR@/inspircd.pid" ]
		then
			kill -HUP $(cat "@ABSOLUTE_RUNTIME_DIR@/inspircd.pid")
		elif [ -d /lib/systemd ]
		then
			if systemctl --quiet is-active inspircd
			then
				systemctl kill --signal HUP inspircd
			fi
		elif [ -x "@ABSOLUTE_SCRIPT_DIR@/inspircd" ]
		then
			"@ABSOLUTE_SCRIPT_DIR@/inspircd" rehash
		fi
	endscript
}

import argparse
import configparser
import hashlib
import json
import pathlib
import re
import sys
import urllib.request

from src.python import common, console, module

CONTRIB_MODULES = module.CONTRIB_DIR / "installed-modules.json"
CONTRIB_SOURCES = module.CONTRIB_DIR / "module-sources.ini"


def fetch_http(url):
    try:
        with urllib.request.urlopen(url) as response:
            return response.read().decode("utf-8")

    except (urllib.error.HTTPError, urllib.error.URLError, OSError) as e:
        console.error(f"Unable to download {console.color(url, console.BOLD)}: {e}")


def fetch_modules(repository):
    config = configparser.ConfigParser()
    config.read(CONTRIB_SOURCES)

    modules = {}
    for section in config.sections():
        if repository and repository not in section:
            continue  # Not what we're looking for.

        repo = config[section]
        if "url" not in repo:
            console.warning(f"The {section} repository does not have an URL associated with it!")
            continue

        fetch_repository(section, repo, modules)
    return modules


def fetch_repository(name, repository, modules):
    repository_url = repository["url"]
    console.debug(f"Fetching modules for {name} from {repository_url}")

    data = fetch_http(repository_url)
    if data:
        module_config = None
        for line in data.splitlines():
            if match := re.fullmatch(r"\s*module (\S+) (\S+) (.+)", line, re.IGNORECASE):
                module_name = match.group(1)
                modules.setdefault(module_name, [])
                module_config = {
                    "author":          [],
                    "checksum":        "",
                    "conflicts":       {},
                    "depends":         {},
                    "description":     "",
                    "mask":            "",
                    "name":            module_name,
                    "repository":      name,
                    "repository-desc": repository["description"],
                    "url":             match.group(3),
                    "version":         module.version_parse(match.group(2))
                }
                modules[module_name].append(module_config)

            elif match := re.fullmatch(r"\s*author\s+(.+)", line, re.IGNORECASE):
                module_config["author"].append(match.group(1))

            elif match := re.fullmatch(r"\s*checksum\s+(\S+)", line, re.IGNORECASE):
                module_config["checksum"] = match.group(1)

            elif match := re.fullmatch(r"\s*conflicts\s+(\S+)(?:\s+(.+))", line, re.IGNORECASE):
                module_config["conflicts"][match.group(1)] = match.group(2)

            elif match := re.fullmatch(r"^\s*depends\s+(\S+)\s+(\d+(?:\.\d+)*)(?:-(\d+(?:\.\d+)*))?", line, re.IGNORECASE):
                oldest_version = module.version_parse(match.group(2))
                newest_version = module.version_parse(match.group(3)) if match.group(3) else oldest_version
                module_config["depends"][match.group(1)] = (oldest_version, newest_version)

            elif match := re.fullmatch(r"\s*description\s+(.+)", line, re.IGNORECASE):
                module_config["description"] = match.group(1)

            elif match := re.fullmatch(r"\s*mask\s+(.+)", line, re.IGNORECASE):
                module_config["mask"] = match.group(1)

            elif match := re.fullmatch(r"\s*source\s+(.+)", line, re.IGNORECASE):
                fetch_repository(repository, match.group(1), modules)

            elif line:
                console.debug(f"Unknown line: {line}")


def find_module(modules, name, repository):
    short_name = module.short_name(name)
    selected_module = None
    for module_data in modules.get(short_name, {}):
        if repository and repository != module_data["repository"]:
            continue

        version = module_data["version"]
        if not selected_module or module.version_compare(selected_module["version"], version) > 0:
            console.debug(f"Potential remote module match: {name} {module.version_string(version)}")
            selected_module = module_data

    if selected_module:
        console.debug(f"Remote dependency match: {name} {module.version_string(selected_module['version'])}")

    return selected_module


def resolve_conflicts(dependencies, module_to_install):
    module_to_install_name = module_to_install["name"]
    for conflict_module, conflict_reason in module_to_install["conflicts"].items():
        console.debug(f"The {module_to_install_name} conflicts with {conflict_module}: {conflict_reason}")
        if conflict_module in dependencies:
            console.error(f"The {module_to_install_name} module can not be installed whilst the {conflict_module} is installed: {conflict_reason}")


def resolve_dependencies(dependencies, installed_modules, remote_modules, module_to_install):
    module_to_install_name = module_to_install["name"]
    modules_to_install = []

    for required_module, required_version in module_to_install["depends"].items():
        requirement = required_module + " " + module.version_range_string(required_version)
        console.debug(f"The {module_to_install_name} depends on {requirement}")

        # Check for the dependency locally.
        dependency = dependencies.get(required_module)
        if dependency and module.version_in_range(dependency, required_version):
            console.debug(f"Local dependency match: {required_module} {module.version_string(dependency)}")
            continue

        # Check for the dependency in the remotes.
        remote_selection = None
        for remote_module in remote_modules.get(required_module, []):
            remote_version = remote_module["version"]
            if not module.version_in_range(remote_version, required_version):
                console.debug(f"Remote dependency not suitable: {required_module} {module.version_string(remote_version)}")
                continue

            # Check for a more recent potential dependency.
            if not remote_selection or module.version_compare(remote_selection["version"], remote_version) > 0:
                console.debug(f"Potential remote dependency match: {required_module} {module.version_string(remote_version)}")
                remote_selection = remote_module

        if not remote_selection:
            console.error(f"Unable to find a module matching {console.color(requirement, console.BOLD)} in any remotes.")

        console.debug(f"Remote dependency match: {required_module} {module.version_string(remote_selection['version'])}")
        modules_to_install.append(remote_selection)

    return modules_to_install


def install_module(dependencies, installed_modules, remote_modules, module_to_install, upgrade):
    module_to_install_name = module_to_install["name"]
    if module_to_install_name in dependencies and not upgrade:
        console.debug(f"The {module_to_install_name} module is already installed.")
        return

    module_to_install_version = module.version_string(module_to_install["version"])
    print(f"Installing version {console.color(module_to_install_version, console.BOLD)} of the {console.color(module_to_install_name, console.BOLD)} module ...")

    resolve_conflicts(dependencies, module_to_install)
    for module_dependency in resolve_dependencies(dependencies, installed_modules, remote_modules, module_to_install):
        install_module(dependencies, installed_modules, remote_modules, module_dependency, upgrade)

    try:
        contents = fetch_http(module_to_install["url"])

        actual_checksum = hashlib.sha256(contents.encode("utf-8")).hexdigest()
        if "checksum" in module_to_install:
            expected_checksum = module_to_install["checksum"]
            if actual_checksum != expected_checksum:
                console.error(
                    f"Checksum for the {console.color(module_to_install_name, console.BOLD)} module did not match, possibly corrupt module detected.",
                    f"Expected checksum: {expected_checksum}",
                    f"Actual checksum:   {actual_checksum}",
                )

        else:
            console.warning(f"The module source for {console.color(module_to_install_name, console.BOLD)} module did not specify a checksum, unable to detect corruption.")

        with open(module.CONTRIB_DIR / module.file_name(module_to_install_name), "w", encoding="utf-8") as fh:
            fh.write(contents)

        dependencies[module_to_install_name] = module_to_install["version"]
        installed_modules[module_to_install_name] = {
            "checksum": actual_checksum,
            "repository": module_to_install["repository"],
            "version": module_to_install_version,
        }

    except OSError as e:
        console.error(f"Unable to write module source: {e}")


def installed_dependencies(installed_modules):
    dependencies = {}

    # Core
    core_version = common.version()
    dependencies["core"] = (core_version["MAJOR"], core_version["MINOR"], core_version["PATCH"])

    # Official modules
    for long_module in module.DIR.iterdir():
        if long_module.suffix == ".cpp":
            short_name = module.short_name(long_module)
            dependencies[short_name] = dependencies["core"]

    # Installed modules
    for module_name, module_data in installed_modules.items():
        dependencies[module_name] = module.version_parse(module_data["version"])

    return dependencies


def load_contrib_manifest():
    try:
        console.debug(f"Reading the contrib module manifest from {CONTRIB_MODULES} ...")
        with open(CONTRIB_MODULES, "r", encoding="utf-8") as fh:
            return json.load(fh)

    except FileNotFoundError:
        return {}  # No contrib modules installed

    except (OSError, json.JSONDecodeError) as e:
        console.error(f"Unable to read contrib module manifest: {e}")


def save_contrib_manifest(installed_modules):
    try:
        console.debug(f"Writing the contrib module manifest to {CONTRIB_MODULES} ...")
        with open(CONTRIB_MODULES, "w", encoding="utf-8") as fh:
            json.dump(installed_modules, fh, indent=4)

    except OSError as e:
        console.error(f"Unable to write contrib module manifest: {e}")



    return console.subcommand(args, 2, {
        "info": {
            "function": cmd_contrib_info,
            "help": "Install a module from a contrib repository",
            "options": {
                "--only-installed": "Only list modules that are installed",
                "--repository REPO": "The repository to show modules from",
            }
        },
        "install": {
            "function": cmd_contrib_install,
            "help": "Install a module from a contrib repository",
            "options": {
                "--repository REPO": "The repository to install modules from",
            }
        },
        "list": {
            "function": cmd_contrib_list,
            "help": "List available contrib modules",
            "options": {
                "--only-installed": "Only list modules that are installed",
                "--repository REPO": "The repository to list modules from",
                "--show-masked": "Show modules that have been masked",
            },
        },
        "uninstall": {
            "function": cmd_contrib_uninstall,
            "help": "Uninstall a module installed from a contrib repository",
        },
        "upgrade": {
            "function": cmd_contrib_upgrade,
            "help": "Update installed contrib modules",
        },

        # Helper aliases for common synonyms.
        "update": {
            "function": cmd_contrib_upgrade,
        },
    })


def cmd_contrib_info(commands, args, start):
    parser = argparse.ArgumentParser(add_help=False)
    parser.add_argument("--only-installed", help="Only list modules that are installed", action="store_true")
    parser.add_argument("--repository", help="The repository to list modules from", metavar="REPO")
    (options, modules_to_show) = parser.parse_known_args(args[start:])

    if not modules_to_show:
        console.error("You must specify one or more modules to show information about.")

    installed_modules = load_contrib_manifest()
    remote_modules = fetch_modules(options.repository)

    for module_name in modules_to_show:
        short_name = module.short_name(module_name)
        if short_name not in remote_modules:
            console.warning(f"The {console.color(short_name, console.BOLD)} module is not available.")
            continue  # Nothing to do

        print(f"Information about the {console.color(short_name, console.BOLD)} module:")
        print()

        for idx, remote_module in enumerate(remote_modules[short_name]):
            if idx:
                print("---")

            data = []
            data.append(["Description", remote_module["description"]])
            data.append(["Repository",  f"{remote_module['repository-desc']} ({remote_module['repository']})"])

            for author in remote_module["author"]:
                data.append(["Author", author])

            for conflict_module, conflict_reason in remote_module["conflicts"].items():
                data.append(["Conflicts with",  f"{conflict_module} ({conflict_reason})"])

            for required_module, required_version in remote_module["depends"].items():
                data.append(["Depends on", f"{required_module} {module.version_range_string(required_version)}"])

            if remote_module["mask"]:
                data.append(["Mask reason", remote_module['mask']])

            if short_name in installed_modules:
                installed_module = installed_modules[short_name]
                if installed_module["repository"] == remote_module["repository"]:
                    match module.version_compare(module.version_parse(installed_module["version"]), remote_module["version"]):
                        case -1:  # Outdated
                            data.append(["Status", "outdated"])
                        case 0:  # Up-to-date
                            data.append(["Status", "up to date"])
                        case 1:  # More recent than contrib
                            data.append(["Status", "more recent"])
                else:
                    data.append(["Status", "installed from different repository"])
            else:
                data.append(["Status", "not installed"])

            console.table(None, data, ":")


def cmd_contrib_install(commands, args, start):
    parser = argparse.ArgumentParser(add_help=False)
    parser.add_argument("--repository", help="The repository to list modules from", metavar="REPO")
    (options, modules_to_install) = parser.parse_known_args(args[start:])

    if not modules_to_install:
        console.error("You must specify one or more modules to install.")

    installed_modules = load_contrib_manifest()
    dependencies = installed_dependencies(installed_modules)
    remote_modules = fetch_modules(options.repository)

    modules_installed = False
    for module_name in modules_to_install:
        short_name = module.short_name(module_name)
        if short_name in installed_modules:
            console.warning(f"The {console.color(short_name, console.BOLD)} module is already installed.")
            continue  # Nothing to do

        remote_module = find_module(remote_modules, short_name, options.repository)
        if not remote_module:
            console.warning(f"The {console.color(short_name, console.BOLD)} module is not available in any repository.")
            continue  # Not available

        install_module(dependencies, installed_modules, remote_modules, remote_module, False)
        modules_installed = True

    if modules_installed:
        save_contrib_manifest(installed_modules)


def cmd_contrib_list(commands, args, start):
    parser = argparse.ArgumentParser(add_help=False)
    parser.add_argument("--only-installed", help="Only list modules that are installed", action="store_true")
    parser.add_argument("--repository", help="The repository to list modules from", metavar="REPO")
    parser.add_argument("--show-masked", help="Show modules that have been masked", action="store_true")
    (options, _) = parser.parse_known_args(args[start:])

    installed_modules = load_contrib_manifest()
    remote_modules = fetch_modules(options.repository)

    module_table = []
    dependencies = installed_dependencies(installed_modules)

    for module_name, remote_variants in sorted(remote_modules.items()):
        for remote_module in remote_variants:
            available_core = dependencies.get("core")
            module_core = remote_module["depends"].get("core")
            if not module.version_in_range(available_core, module_core):
                continue  # Module is not for this core version

            installed_module = installed_modules.get(module_name)
            version_string = module.version_string(remote_module["version"])
            if installed_module:
                if installed_module["repository"] == remote_module["repository"]:
                    match module.version_compare(module.version_parse(installed_module["version"]), remote_module["version"]):
                        case -1:  # Outdated
                            version_string = console.color(version_string, console.BOLD_RED)
                        case 0:  # Up-to-date
                            version_string = console.color(version_string, console.BOLD_GREEN)
                        case 1:  # More recent than contrib
                            version_string = console.color(version_string, console.BOLD_YELLOW)

            elif options.only_installed:
                continue  # Not installed

            remote_mask = remote_module["mask"]
            if remote_mask:
                if options.show_masked:
                    module_name = console.color(module_name, console.FAINT)

                else:
                    console.debug(f"Module {module_name} {version_string} from {remote_module['repository']} is masked: {remote_mask}")
                    continue

            module_table.append([module_name, version_string, remote_module["description"]])

    if not module_table:
        console.error("No modules matching your requirements are available.")

    console.table(["Module", "Version", "Description"], module_table)


def cmd_contrib_uninstall(commands, args, start):
    if len(args) <= start:
        console.error("You must specify one or more modules to uninstall.")

    installed_modules = load_contrib_manifest()
    for module_name in args[start:]:
        short_name = module.short_name(module_name)
        long_module = module.CONTRIB_DIR / module.file_name(module_name)

        if not long_module.is_file():
            console.error(f"The {console.color(short_name, console.BOLD)} module is not installed.")

        elif short_name not in installed_modules:
            console.error(f"The {console.color(short_name, console.BOLD)} module is not a contrib module.")

        try:
            print(f"Removing the {console.color(short_name, console.BOLD)} module ...")
            long_module.unlink()
            del installed_modules[short_name]

        except OSError as e:
            console.error(f"Unable to unlink {long_module}: {e}")

    save_contrib_manifest(installed_modules)


def cmd_contrib_upgrade(commands, args, start):
    installed_modules = load_contrib_manifest()
    dependencies = installed_dependencies(installed_modules)
    remote_modules = fetch_modules(None)

    modules_to_upgrade = args[start:]
    if not modules_to_upgrade:
        modules_to_upgrade = list(installed_modules.keys())

    modules_upgraded = False
    for module_name in modules_to_upgrade:
        short_name = module.short_name(module_name)
        if short_name not in installed_modules:
            console.error(f"The {console.color(short_name, console.BOLD)} module is not installed.")

        installed_module = installed_modules[short_name]
        remote_repository = installed_module["repository"]
        remote_module = find_module(remote_modules, short_name, remote_repository)
        if not remote_module:
            console.warning(f"The {console.color(short_name, console.BOLD)} module is not available in the {remote_repository} repository.")
            continue

        installed_version = installed_module["version"]
        remote_version = remote_module["version"]
        if module.version_compare(module.version_parse(installed_version), remote_version) >= 0:
            print(f"The {console.color(short_name, console.BOLD)} module is up to date.")
            continue  # Module up to date

        try:
            with open(module.CONTRIB_DIR / module.file_name(module_name), "rb") as fh:
                file_checksum = hashlib.file_digest(fh, "sha256").hexdigest()
                installed_checksum = installed_module["checksum"]
                if installed_checksum != file_checksum:
                    console.warning(
                        f"Local checksum for the {console.color(short_name, console.BOLD)} module did not match; not updating.",
                        f"Expected checksum: {installed_checksum}",
                        f"Actual checksum:   {file_checksum}",
                    )
                    continue  # Locally modified

        except OSError as e:
            console.warning(f"Unable to checksum {short_name}: {e}")

        print(f"Upgrading the {console.color(short_name, console.BOLD)} module from {console.color(installed_version, console.BOLD)} ...")
        install_module(dependencies, installed_modules, remote_modules, remote_module, True)
        modules_upgraded = True

    if modules_upgraded:
        save_contrib_manifest(installed_modules)


def cmd_extra(commands, args, start):
    return console.subcommand(args, 2, {
        "disable": {
            "function": cmd_extra_disable,
            "help": "Disable one or more extra modules",
        },
        "enable": {
            "function": cmd_extra_enable,
            "help": "Enable one or more extra modules",
        },
        "list": {
            "function": cmd_extra_list,
            "help": "List the status of extra modules",
        },
    })


def cmd_extra_disable(commands, args, start):
    if len(args) <= start:
        console.error("You must specify one or more modules to disable.")

    for module_name in args[start:]:
        short_name = module.short_name(module_name)
        long_module = module.DIR / module.file_name(module_name)
        long_extra = module.EXTRA_DIR / module.file_name(module_name)

        if not long_module.exists():
            if not long_extra.exists():
                console.error(f"The {console.color(short_name, console.BOLD)} module is not an extra module.")

            elif long_module.is_symlink() and long_extra.readlink() != long_extra:
                console.error(f"The {console.color(short_name, console.BOLD)} module is not a symlink to an extra module.")

            else:
                console.warning(f"The {console.color(short_name, console.BOLD)} module is not currently enabled.")
                continue  # Nothing to do.

        try:
            print(f"Disabling the {console.color(short_name, console.BOLD)} module ...")
            long_module.unlink(long_extra)

        except OSError as e:
            console.error(f"Unable to unlink {short_name} from {long_extra}: {e}")

    cmd_extra_list(commands, args, start)


def cmd_extra_enable(commands, args, start):
    if len(args) <= start:
        console.error("You must specify one or more modules to enable.")

    for module_name in args[start:]:
        short_name = module.short_name(module_name)
        long_extra = module.EXTRA_DIR / module.file_name(module_name)

        if not long_extra.exists():
            console.error(f"{console.color(short_name, console.BOLD)} is not an extra module!")

        long_module = module.DIR / module.file_name(module_name)
        if long_module.is_symlink():
            if long_module.readlink() == long_extra:
                console.warning(f"The {console.color(short_name, console.BOLD)} module is already enabled.")
                continue  # Nothing to do

            else:
                long_module.unlink(missing_ok=True)  # Remove the dead symlink.

        try:
            print(f"Enabling the {console.color(short_name, console.BOLD)} module ...")
            long_module.symlink_to(long_extra)

        except OSError as e:
            console.error(f"Unable to symlink {short_name} to {long_extra}: {e}")

    cmd_extra_list(commands, args, start)


def cmd_extra_list(commands, args, start):
    modules = []
    for long_extra in module.EXTRA_DIR.iterdir():
        if not long_extra.suffix == ".cpp":
            continue  # Not a module

        long_module = module.DIR / long_extra.name
        short_module = module.short_name(long_extra)
        if long_module.is_symlink():
            if long_module.readlink() == long_extra:
                modules.append([short_module, console.color("enabled", console.BOLD_GREEN)])

            else:
                modules.append([short_module, console.color("not an extra symlink", console.BOLD_YELLOW)])

        elif long_module.exists():
            modules.append([short_module, console.color("not a symlink", console.BOLD_RED)])

        else:
            modules.append([short_module, console.color("disabled", console.BOLD_YELLOW)])

    console.table(["Name", "Status"], modules)


sys.exit(console.subcommand(sys.argv, 1, {
    "contrib": {
        "function": cmd_contrib,
        "help": "Manipulate contrib modules",
    },
    "extra": {
        "function": cmd_extra,
        "help": "Manipulate extra modules",
    },

    # These commands exist for compatibility with v4 and earlier.
    "install": {
        "function": cmd_contrib_install,
    },
    "list": {
        "function": cmd_contrib_list,
    },
    "upgrade": {
        "function": cmd_contrib_upgrade,
    },
}))
